.container {
  min-height: 100vh;
  background: #F3F4F6;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 活动信息卡 */
.info-card {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 32rpx 32rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.activity-title-row {
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.4;
}

.info-list {
  margin-bottom: 28rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
  width: 36rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
}

/* 位置状态栏 */
.location-bar {
  padding: 0;
  margin-top: 20rpx;
}

.location-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
}

.location-valid {
  background: rgba(16, 185, 129, 0.2);
  border-color: rgba(16, 185, 129, 0.4);
}

.location-invalid {
  background: rgba(239, 68, 68, 0.2);
  border-color: rgba(239, 68, 68, 0.4);
}

.location-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  flex: 1;
  line-height: 1.4;
}

.location-refresh {
  margin-left: 16rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 8rpx;
  padding: 8rpx 18rpx;
}

.location-refresh text {
  font-size: 22rpx;
  color: #FFFFFF;
}

/* 签到状态卡片 */
.status-card {
  margin: 32rpx 32rpx 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.07);
}

/* 已签到 */
.checked-status {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.checked-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #10B981, #34D399);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.checked-icon {
  font-size: 56rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.checked-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.checked-time {
  font-size: 28rpx;
  color: #10B981;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.checked-name {
  font-size: 24rpx;
  color: #9CA3AF;
}

/* 未签到 */
.unchecked-status {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.unchecked-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EEF2FF, #E0E7FF);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.unchecked-icon {
  font-size: 56rpx;
}

.unchecked-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.unchecked-desc {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 40rpx;
  text-align: center;
  line-height: 1.6;
}

/* 签到按钮 */
.checkin-btn {
  width: 480rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #4F46E5, #7C3AED) !important;
  color: #FFFFFF !important;
  font-size: 34rpx !important;
  font-weight: 700 !important;
  letter-spacing: 4rpx;
  border: none !important;
  box-shadow: 0 8rpx 32rpx rgba(79, 70, 229, 0.35);
}

.checkin-btn[disabled] {
  opacity: 0.5;
}

.out-of-range-tip {
  font-size: 22rpx;
  color: #EF4444;
  margin-top: 20rpx;
}

.bottom-space {
  height: 60rpx;
}
