.container {
  min-height: 100vh;
  background: #F3F4F6;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 活动信息卡 */
.info-card {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 32rpx 32rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.activity-title-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.activity-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.4;
}

.info-list {
  margin-bottom: 28rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 14rpx;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
  width: 36rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
}

/* 位置状态栏 */
.location-bar {
  padding: 0 32rpx;
  margin-top: 20rpx;
}

.location-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
}

.location-valid {
  background: rgba(16, 185, 129, 0.2);
  border-color: rgba(16, 185, 129, 0.4);
}

.location-invalid {
  background: rgba(239, 68, 68, 0.2);
  border-color: rgba(239, 68, 68, 0.4);
}

.location-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  flex: 1;
  line-height: 1.4;
}

.location-refresh {
  margin-left: 16rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 8rpx;
  padding: 8rpx 18rpx;
}

.location-refresh text {
  font-size: 22rpx;
  color: #FFFFFF;
}

/* 签到统计 */
.checkin-stats {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
}

.stat-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100rpx;
}

.stat-big {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.1;
}

.stat-small {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  margin-top: 6rpx;
}

.stat-middle {
  flex: 1;
  padding: 0 24rpx;
}

.progress-bar-bg {
  height: 12rpx;
  background: rgba(255,255,255,0.25);
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-bar-fill {
  height: 100%;
  background: #FFFFFF;
  border-radius: 12rpx;
  transition: width 0.4s ease;
}

.progress-text {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  text-align: center;
  display: block;
}

/* 搜索 & 筛选 */
.search-wrap {
  background: #FFFFFF;
  padding: 20rpx 24rpx 0;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.search-bar {
  display: flex;
  align-items: center;
  background: #F3F4F6;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #111827;
}

.clear-icon {
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 0 8rpx;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  border-top: 1rpx solid #F3F4F6;
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #6B7280;
  border-bottom: 4rpx solid transparent;
}

.filter-tab.active {
  color: #4F46E5;
  font-weight: 600;
  border-bottom-color: #4F46E5;
}

/* 人员列表 */
.list-wrap {
  margin: 16rpx 24rpx 0;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #9CA3AF;
  font-size: 28rpx;
}

.person-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.checked-item {
  background: #F0FDF4;
}

/* 头像 */
.person-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.avatar-default {
  background: #EEF2FF;
}

.avatar-checked {
  background: #D1FAE5;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #4F46E5;
}

.avatar-checked .avatar-text {
  color: #065F46;
}

/* 人员信息 */
.person-info {
  flex: 1;
}

.person-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.person-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-right: 12rpx;
}

.person-dept {
  font-size: 22rpx;
  color: #FFFFFF;
  background: #6366F1;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.person-phone {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-bottom: 6rpx;
  display: block;
}

.checked-time {
  font-size: 22rpx;
  color: #10B981;
  font-weight: 600;
}

/* 签到按钮 */
.checkin-btn-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.checkin-btn {
  background: #4F46E5 !important;
  color: #FFFFFF !important;
  font-size: 26rpx !important;
  font-weight: 600 !important;
  padding: 16rpx 28rpx !important;
  border-radius: 12rpx !important;
  border: none !important;
  line-height: 1.4 !important;
  min-width: 120rpx !important;
}

.checked-badge {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #10B981;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
}

.undo-btn {
  background: transparent !important;
  color: #9CA3AF !important;
  font-size: 22rpx !important;
  padding: 8rpx 16rpx !important;
  border-radius: 8rpx !important;
  border: 1rpx solid #E5E7EB !important;
  line-height: 1.4 !important;
}

.bottom-space {
  height: 60rpx;
}
