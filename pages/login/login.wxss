page {
  background: linear-gradient(160deg, #4F46E5 0%, #7C3AED 50%, #2D1B69 100%);
  min-height: 100vh;
}

.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  padding-top: 160rpx;
}

/* Logo 区域 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  filter: drop-shadow(0 8rpx 24rpx rgba(0,0,0,0.3));
}

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
}

/* 登录卡片 */
.login-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 56rpx 48rpx;
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,0.25);
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.card-subtitle {
  display: block;
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 48rpx;
}

/* 输入框 */
.input-wrap {
  display: flex;
  align-items: center;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 100rpx;
  transition: border-color 0.2s;
  margin-bottom: 16rpx;
}

.input-focus {
  border-color: #4F46E5;
  background: #EEF2FF;
}

.input-error {
  border-color: #EF4444;
  background: #FEF2F2;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.staff-input {
  flex: 1;
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
  letter-spacing: 6rpx;
}

.input-placeholder {
  color: #D1D5DB;
  font-size: 28rpx;
  font-weight: 400;
  letter-spacing: 0;
}

.input-clear {
  font-size: 28rpx;
  color: #9CA3AF;
  padding: 8rpx;
}

/* 提示文字 */
.error-tip {
  font-size: 24rpx;
  color: #EF4444;
  padding: 0 4rpx;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.format-tip {
  display: block;
  font-size: 24rpx;
  color: #9CA3AF;
  padding: 0 4rpx;
  margin-bottom: 12rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none;
  margin-top: 32rpx;
  transition: opacity 0.2s;
}

.login-btn-active {
  background: linear-gradient(135deg, #4F46E5, #7C3AED) !important;
  color: #FFFFFF !important;
}

.login-btn-disabled {
  background: #E5E7EB !important;
  color: #9CA3AF !important;
}

/* 底部 */
.footer-tip {
  margin-top: 48rpx;
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}
