.container {
  min-height: 100vh;
  background: #F3F4F6;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #9CA3AF;
}

/* 表单卡片 */
.form-card {
  background: #FFFFFF;
  margin: 24rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.07);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-row {
  display: flex;
  gap: 24rpx;
}

.form-half {
  flex: 1;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 16rpx;
}

.required {
  color: #EF4444;
  font-size: 28rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #111827;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4F46E5;
  background: #FFFFFF;
}

/* 地点行 */
.location-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.location-input {
  flex: 1;
}

.location-btn {
  width: 80rpx;
  height: 80rpx;
  background: #F3F4F6;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 32rpx;
}

.form-hint {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  margin-top: 10rpx;
  line-height: 1.4;
}

/* Picker */
.form-picker {
  height: 80rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #111827;
}

.picker-placeholder {
  color: #9CA3AF;
}

.picker-arrow {
  font-size: 36rpx;
  color: #9CA3AF;
  font-weight: 300;
}

/* Textarea */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F9FAFB;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #111827;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 操作按钮 */
.action-area {
  padding: 16rpx 24rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  color: #FFFFFF !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  border-radius: 16rpx !important;
  border: none !important;
  line-height: 88rpx !important;
}

.btn-disabled {
  opacity: 0.6;
}

.delete-btn {
  width: 100%;
  height: 88rpx;
  background: #FFFFFF !important;
  color: #EF4444 !important;
  font-size: 28rpx !important;
  font-weight: 500 !important;
  border-radius: 16rpx !important;
  border: 2rpx solid #FCA5A5 !important;
  line-height: 88rpx !important;
  margin-top: 20rpx;
}

.bottom-space {
  height: 60rpx;
}
