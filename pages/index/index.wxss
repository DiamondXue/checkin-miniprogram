.container {
  min-height: 100vh;
  background: #F3F4F6;
  padding-bottom: 40rpx;
}

/* 顶部统计 */
.header-stats {
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  padding: 56rpx 32rpx 48rpx;
}

/* 用户信息栏 */
.user-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.user-greeting {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
}

.logout-btn {
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 8rpx 24rpx;
}

.logout-btn text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-num {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 64rpx;
  background: rgba(255,255,255,0.25);
}

/* 分区标题 */
.section-title {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6B7280;
}

.section-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.ongoing-dot { background: #10B981; }
.upcoming-dot { background: #3B82F6; }
.ended-dot { background: #D1D5DB; }

/* 活动卡片 */
.activity-card {
  margin: 12rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.07);
}

.ended-card {
  opacity: 0.75;
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.activity-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
  flex: 1;
  margin-right: 16rpx;
  line-height: 1.4;
}

.ended-name {
  color: #9CA3AF;
}

/* 活动信息 */
.activity-info {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.info-icon {
  font-size: 26rpx;
  margin-right: 12rpx;
  width: 36rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.5;
}

.ended-text {
  color: #9CA3AF;
}

/* 进度条 */
.progress-area {
  margin-bottom: 20rpx;
}

.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #6B7280;
  margin-bottom: 10rpx;
}

.progress-num {
  font-weight: 600;
  color: #374151;
}

.progress-bar-bg {
  height: 10rpx;
  background: #E5E7EB;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.ongoing-fill { background: linear-gradient(90deg, #10B981, #34D399); }
.ended-fill { background: #9CA3AF; }

/* 卡片底部 */
.card-footer {
  border-top: 1rpx solid #F3F4F6;
  padding-top: 20rpx;
  text-align: right;
}

.go-text {
  font-size: 26rpx;
  color: #4F46E5;
  font-weight: 600;
}

.bottom-space {
  height: 40rpx;
}
